<?xml version="1.0" encoding="utf-8"?>
<!-- Foreground for the adaptive launcher icon. Uses the exact path the
     in-app <Flame/> icon (lucide-react) renders, so the APK drawer icon
     and the in-app header badge match.
     Canvas is 108dp with a 72dp safe zone (Android adaptive icon spec).
     The lucide path is a 24-unit glyph; we map viewport to 108 and scale
     by 3× centered at (54, 54) so the flame fills ~72dp. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
  <group
      android:translateX="18"
      android:translateY="18"
      android:scaleX="3"
      android:scaleY="3">
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M8.5,14.5 A 2.5 2.5 0 0 0 11 12 C 11 10.62 10.5 10 10 9 C 8.928 6.857 9.776 4.946 12 3 C 12.5 5.5 14 7.9 16 9.5 C 18 11.1 19 13 19 15 A 7 7 0 0 1 5 15 C 5 13.847 5.433 12.706 6 12 A 2.5 2.5 0 0 0 8.5 14.5 Z"/>
  </group>
</vector>
