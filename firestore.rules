rules_version = '2';

// Zenith Fitness — Firestore security rules.
//
// Collections:
//   userProfiles/{uid}           — public profile (search), owner-writable
//   users/{uid}/data/{doc}       — private per-user data (workouts, settings, …)
//   buddies/{pairId}             — mutual friendship (sorted uid1_uid2)
//   buddyRequests/{requestId}    — pending friendship requests
//   chats/{chatId}               — chat doc; messages nested
//   notifications/{uid}/items/…  — in-app notifications
//   workoutSessions/{id}         — group workout sessions + subcollections
//   shared/{document}            — shared exercise library
//
// The read rule on userProfiles intentionally allows any signed-in user to
// read any profile so search + buddy comparison work across accounts.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // ---------- userProfiles ----------
    // Publicly readable by authenticated users (for search + comparison).
    // Only the owner can write their own profile.
    match /userProfiles/{uid} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // ---------- per-user private data ----------
    // Workouts, exercises, templates, records — only the owner can read/write.
    match /users/{uid}/{doc=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // ---------- buddy requests ----------
    match /buddyRequests/{requestId} {
      allow read:   if signedIn() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if signedIn() && request.auth.uid == request.resource.data.fromUid;
      allow update: if signedIn() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow delete: if signedIn() && (
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
    }

    // ---------- buddy relationships ----------
    // pairId is a deterministic "sorted_uid1_uid2". `users` is a 2-element array.
    match /buddies/{pairId} {
      allow read:   if signedIn() && request.auth.uid in resource.data.users;
      allow create: if signedIn() && request.auth.uid in request.resource.data.users;
      allow update: if signedIn() && request.auth.uid in resource.data.users;
      allow delete: if signedIn() && request.auth.uid in resource.data.users;
    }

    // ---------- chats + messages ----------
    match /chats/{chatId} {
      allow read:   if signedIn() && request.auth.uid in resource.data.users;
      allow create: if signedIn() && request.auth.uid in request.resource.data.users;
      allow update: if signedIn() && request.auth.uid in resource.data.users;

      match /messages/{messageId} {
        allow read:   if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.users;
        allow create: if signedIn() && request.auth.uid == request.resource.data.senderId;
        allow update: if false;
        allow delete: if signedIn() && request.auth.uid == resource.data.senderId;
      }
    }

    // ---------- notifications ----------
    // Only the recipient can read. Any signed-in user can create (senders
    // include buddy requests, chat notifications, session invites, etc.).
    match /notifications/{uid}/items/{notifId} {
      allow read:   if signedIn() && request.auth.uid == uid;
      allow create: if signedIn();
      allow update: if signedIn() && request.auth.uid == uid;
      allow delete: if signedIn() && request.auth.uid == uid;
    }

    // ---------- workoutSessions ----------
    // `participants` is a map keyed by uid. `in` on a map checks key membership.
    match /workoutSessions/{sessionId} {
      allow read:   if signedIn() && (
        request.auth.uid == resource.data.hostUid ||
        request.auth.uid in resource.data.participants
      );
      allow create: if signedIn() && request.auth.uid == request.resource.data.hostUid;
      allow update: if signedIn() && (
        request.auth.uid == resource.data.hostUid ||
        request.auth.uid in resource.data.participants
      );
      allow delete: if signedIn() && request.auth.uid == resource.data.hostUid;

      // Per-participant live progress snapshot.
      match /progress/{uid} {
        allow read:   if signedIn();
        allow write:  if signedIn() && request.auth.uid == uid;
      }

      // Ephemeral reaction stream.
      match /reactions/{reactionId} {
        allow read:   if signedIn();
        allow create: if signedIn() && request.auth.uid == request.resource.data.fromUid;
      }
    }

    // ---------- shared exercise library ----------
    match /shared/{document} {
      allow read:   if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
    }
  }
}
