# Copy to .env.local (or set in CI) to enable optional features.
# All of these are read at build time by Vite.

# ----- Web Push (browser / PWA) -----
# Paste the public VAPID key from
#   Firebase console → Project settings → Cloud Messaging → Web Push certificates.
# Without this the web (Chrome) push path stays disabled.
# Not needed for the Android APK — that uses the Capacitor push plugin.
VITE_FCM_VAPID_KEY=

# ----- Vercel push fan-out endpoint -----
# Your deployed Vercel function URL. Example:
#   https://zenith-fitness-push.vercel.app/api/push
# Without this the app still writes the in-app Firestore notification
# (so in-app toasts work), but no system-tray push is fired.
VITE_PUSH_ENDPOINT=
